<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="170dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="14dp"
    android:background="@drawable/bg_card_white"
    android:orientation="vertical"
    android:padding="18dp">

    <!-- İkon kutusu (yeşil veya turuncu) -->
    <FrameLayout
        android:id="@+id/itemSeriIconBox"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_icon_square_green">

        <ImageView
            android:id="@+id/itemSeriIcon"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_bike" />
    </FrameLayout>

    <TextView
        android:id="@+id/itemSeriLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:letterSpacing="0.05"
        android:text="ULAŞIM"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/itemSeriDays"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="12 Gün"
        android:textColor="@color/text_primary"
        android:textSize="26sp"
        android:textStyle="bold" />

    <ProgressBar
        android:id="@+id/itemSeriProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="12dp"
        android:max="100"
        android:progress="80"
        android:progressDrawable="@drawable/progress_horizontal_green" />

</LinearLayout>
