<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="20dp"
    android:background="@drawable/bg_card_white"
    android:orientation="vertical">

    <!-- Makale görseli -->
    <ImageView
        android:id="@+id/itemMakaleImage"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@drawable/bg_image_placeholder"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_image_placeholder" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Etiket: DOĞA GÜNLÜĞÜ vb. -->
        <TextView
            android:id="@+id/itemMakaleTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.05"
            android:text="DOĞA GÜNLÜĞÜ"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- Başlık -->
        <TextView
            android:id="@+id/itemMakaleTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Yerel Ekosistemi Korumak"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Açıklama -->
        <TextView
            android:id="@+id/itemMakaleDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:text="Bahçenizde biyoçeşitliliği artırmak için uygulayabileceğiniz basit adımlar."
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <!-- Tarih + yer imi satırı -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/itemMakaleDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="12 EKİM 2023"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <ImageView
                android:id="@+id/itemMakaleBookmark"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_bookmark" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
